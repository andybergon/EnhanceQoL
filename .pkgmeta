package-as: EnhanceQoL

externals:
  EnhanceQoL/libs/LibDataBroker-1.1:
    url: https://github.com/tekkub/libdatabroker-1-1
    tag: latest

enable-nolib-creation: no

ignore:
  - .DS_Store
  - .env
  - .git
  - .github
  - .gitignore
  - .luacheckrc
  - .release
  - scripts
  - .vscode
  - agents
  - docs
  - News
  - DESCRIPTION.md
  - Features.md
  - generate_changelog.sh
  - LICENSE
  - README.md
  - CONTRIBUTING.md
  - stylua.toml
  - wow-ui-retail.skill

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

move-folders:
  EnhanceQoL/EnhanceQoL: EnhanceQoL
  EnhanceQoL/EnhanceQoLSharedMedia: EnhanceQoLSharedMedia
